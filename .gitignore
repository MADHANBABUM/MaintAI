```gitignore
# Python
__pycache__/
*.pyc
venv/

# Node.js
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js
.next/
out/

# Build
build/
dist/

# Testing
coverage/

# Environment files
.env
.env.local
.env*

# VS Code
.vscode/

# Vercel
.vercel/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Misc
.DS_Store
Thumbs.db
*.pem
```
